<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" width="100%" height="100%">
  <defs>
    <linearGradient id="sky" x1="0%" y1="100%" x2="0%" y2="0%">
      <stop offset="0%" stop-color="#111827" />
      <stop offset="60%" stop-color="#030712" />
      <stop offset="100%" stop-color="#000000" />
    </linearGradient>
    <linearGradient id="neon-glow-cyan" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#22d3ee" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#0891b2" stop-opacity="0" />
    </linearGradient>
    <linearGradient id="neon-glow-pink" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#f472b6" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#db2777" stop-opacity="0" />
    </linearGradient>
    <radialGradient id="headlight" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#fef08a" stop-opacity="0.6" />
      <stop offset="100%" stop-color="#fef08a" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- Widescreen base -->
  <rect width="800" height="450" fill="url(#sky)" />

  <!-- Rain Lines (background) -->
  <g stroke="#9ca3af" stroke-width="0.3" opacity="0.15" stroke-dasharray="8,15">
    <line x1="50" y1="0" x2="30" y2="450" />
    <line x1="150" y1="0" x2="130" y2="450" />
    <line x1="250" y1="0" x2="230" y2="450" />
    <line x1="350" y1="0" x2="330" y2="450" />
    <line x1="450" y1="0" x2="430" y2="450" />
    <line x1="550" y1="0" x2="530" y2="450" />
    <line x1="650" y1="0" x2="630" y2="450" />
    <line x1="750" y1="0" x2="730" y2="450" />
  </g>

  <!-- Cyberpunk Cityscape Background Silhouettes -->
  <g fill="#090d16">
    <rect x="40" y="80" width="120" height="320" />
    <rect x="200" y="140" width="90" height="260" />
    <rect x="320" y="50" width="100" height="350" />
    <rect x="480" y="120" width="130" height="280" />
    <rect x="650" y="60" width="110" height="340" />
  </g>

  <!-- Midground Neon Billboard Lights -->
  <!-- Left Cyan sign -->
  <rect x="80" y="120" width="25" height="150" fill="url(#neon-glow-cyan)" opacity="0.3" />
  <rect x="85" y="125" width="15" height="100" fill="none" stroke="#22d3ee" stroke-width="1.5" />
  <text x="92" y="160" fill="#22d3ee" font-family="sans-serif" font-weight="900" font-size="10" writing-mode="tb" text-anchor="middle" glyph-orientation-vertical="0" letter-spacing="4">NEO-TOKYO</text>

  <!-- Right Pink sign -->
  <rect x="520" y="140" width="40" height="120" fill="url(#neon-glow-pink)" opacity="0.4" />
  <rect x="525" y="145" width="30" height="80" fill="none" stroke="#f472b6" stroke-width="1.5" />
  <text x="540" y="170" fill="#f472b6" font-family="sans-serif" font-weight="800" font-size="9" writing-mode="tb" text-anchor="middle" letter-spacing="3">MATRIX</text>

  <!-- Wet asphalt / reflective road -->
  <rect y="310" width="800" height="140" fill="#080c14" />
  
  <!-- Horizontal streaks representing rain/glare reflections on wet road -->
  <g opacity="0.4">
    <!-- Cyan reflections -->
    <ellipse cx="92" cy="340" rx="40" ry="4" fill="#06b6d4" filter="blur(2px)" />
    <ellipse cx="92" cy="365" rx="65" ry="8" fill="#06b6d4" opacity="0.2" filter="blur(4px)" />
    
    <!-- Pink reflections -->
    <ellipse cx="540" cy="345" rx="45" ry="5" fill="#f472b6" filter="blur(2px)" />
    <ellipse cx="540" cy="370" rx="80" ry="10" fill="#f472b6" opacity="0.2" filter="blur(4px)" stroke-dasharray="10,5" />
  </g>

  <!-- Futuristic Cyber Sports Car Profile (Driving towards left) -->
  <g transform="translate(240, 260)">
    <!-- Red Taillight exhaust plume -->
    <path d="M 310 40 L 350 42 L 310 46 L 305 44 Z" fill="#ef4444" opacity="0.6" filter="blur(1px)" />

    <!-- Car Body Shape -->
    <!-- Lower shadow -->
    <ellipse cx="160" cy="58" rx="140" ry="12" fill="#020408" filter="blur(1.5px)" />
    <!-- Underbody -->
    <rect x="35" y="45" width="250" height="15" fill="#090d16" rx="4" />
    <!-- Main Wedge profile -->
    <path d="M 30 52 L 40 40 Q 90 20 150 15 L 245 20 Q 285 30 295 50 L 30 52 Z" fill="#0e1726" stroke="#334155" stroke-width="1.5" />
    <!-- Canopy (Glass cockpit) -->
    <path d="M 110 24 L 140 16 Q 180 15 210 24 L 225 35 L 105 35 Z" fill="#1e293b" stroke="#475569" stroke-width="1.5" />
    <!-- Neon side trim line on car -->
    <path d="M 45 42 Q 130 35 270 42" stroke="#22d3ee" stroke-width="1.5" fill="none" opacity="0.9" />

    <!-- Headlight shine casting cone to the left -->
    <path d="M 32 46 L -60 25 L -60 75 Z" fill="url(#headlight)" opacity="0.4" />
    <circle cx="32" cy="46" r="3" fill="#fef08a" />

    <!-- Wheels (Low profile cyber wheels with amber rim lights) -->
    <!-- Front Wheel -->
    <circle cx="75" cy="52" r="16" fill="#020408" stroke="#1e293b" stroke-width="1.5" />
    <circle cx="75" cy="52" r="10" fill="none" stroke="#eab308" stroke-width="1.2" opacity="0.8" />
    <!-- Rear Wheel -->
    <circle cx="235" cy="52" r="16" fill="#020408" stroke="#1e293b" stroke-width="1.5" />
    <circle cx="235" cy="52" r="10" fill="none" stroke="#eab308" stroke-width="1.2" opacity="0.8" />
  </g>

  <!-- Foreground Splash Reflections on bottom -->
  <line x1="0" y1="310" x2="800" y2="310" stroke="#374151" stroke-width="1" />

  <!-- Rain splashes (Tiny ripples) -->
  <ellipse cx="150" cy="330" rx="4" ry="1.2" fill="none" stroke="#9ca3af" stroke-width="0.5" opacity="0.4" />
  <ellipse cx="450" cy="360" rx="6" ry="1.5" fill="none" stroke="#9ca3af" stroke-width="0.5" opacity="0.4" />
  <ellipse cx="610" cy="325" rx="3" ry="0.8" fill="none" stroke="#9ca3af" stroke-width="0.5" opacity="0.3" />

  <!-- Top Cinema Black Bar -->
  <rect width="800" height="50" fill="#000000" />
  <!-- Bottom Cinema Black Bar -->
  <rect y="400" width="800" height="50" fill="#000000" />

  <!-- Clip details layout -->
  <text x="40" y="32" font-family="monospace" font-size="11" fill="#475569" letter-spacing="1">CLIP: MOVIE1_SS_CINEMATIC</text>
  <text x="760" y="32" font-family="monospace" font-size="11" fill="#475569" letter-spacing="1" text-anchor="end">02:15:33:14</text>
</svg>
