<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450" width="100%" height="100%">
  <defs>
    <!-- Dark deep space gradient -->
    <radialGradient id="space" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1e1b4b" />
      <stop offset="60%" stop-color="#0f0c29" />
      <stop offset="100%" stop-color="#020005" />
    </radialGradient>
    <!-- Gas giant gradient -->
    <linearGradient id="gas-giant" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#38bdf8" />
      <stop offset="40%" stop-color="#0284c7" />
      <stop offset="80%" stop-color="#1e3a8a" />
      <stop offset="100%" stop-color="#0f172a" />
    </linearGradient>
    <radialGradient id="planet-glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#06b6d4" stop-opacity="0.4" />
      <stop offset="100%" stop-color="#06b6d4" stop-opacity="0" />
    </radialGradient>
    <linearGradient id="neon-hud" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#22c55e" stop-opacity="0.8" />
      <stop offset="50%" stop-color="#10b981" stop-opacity="0.2" />
      <stop offset="100%" stop-color="#06b6d4" stop-opacity="0.8" />
    </linearGradient>
  </defs>

  <!-- Widescreen active canvas -->
  <rect width="800" height="450" fill="url(#space)" />

  <!-- Stars -->
  <g fill="#ffffff" opacity="0.6">
    <circle cx="120" cy="80" r="1" />
    <circle cx="240" cy="140" r="1.5" />
    <circle cx="70" cy="220" r="1" />
    <circle cx="340" cy="50" r="1.2" />
    <circle cx="480" cy="180" r="1" />
    <circle cx="710" cy="90" r="1.5" />
    <circle cx="650" cy="230" r="1" />
  </g>

  <!-- Nebulae/Glow effect -->
  <circle cx="200" cy="200" r="220" fill="url(#planet-glow)" />

  <!-- Gas Giant Planet -->
  <circle cx="200" cy="200" r="110" fill="url(#gas-giant)" />
  <!-- Gas Giant stripes -->
  <path d="M 91 180 Q 200 230 309 180 A 110 110 0 0 1 91 180" fill="#0c4a6e" opacity="0.4" />
  <path d="M 97 160 Q 200 200 303 160 A 110 110 0 0 1 97 160" fill="#e0f2fe" opacity="0.15" />
  <path d="M 112 240 Q 200 280 288 240 A 110 110 0 0 1 112 240" fill="#0284c7" opacity="0.3" />

  <!-- Ship Cockpit Framing Struts (Silhouetted) -->
  <path d="M 0 50 L 150 120 L 250 0 L 0 0 Z" fill="#090d16" stroke="#1e293b" stroke-width="1.5" />
  <path d="M 800 50 L 650 120 L 550 0 L 800 0 Z" fill="#090d16" stroke="#1e293b" stroke-width="1.5" />
  <!-- Lower dash structure -->
  <path d="M 0 400 L 120 340 L 680 340 L 800 400 L 800 450 L 0 450 Z" fill="#05080e" stroke="#111827" stroke-width="2" />
  <!-- Center support column -->
  <path d="M 390 340 L 410 340 L 420 450 L 380 450 Z" fill="#090d16" />

  <!-- Cockpit Glass Reflections -->
  <path d="M 180 80 L 100 280 L 520 280 L 440 80 Z" fill="#ffffff" opacity="0.02" />
  <line x1="300" y1="50" x2="160" y2="400" stroke="#ffffff" stroke-width="0.5" opacity="0.1" />
  <line x1="315" y1="50" x2="180" y2="400" stroke="#ffffff" stroke-width="0.3" opacity="0.08" />

  <!-- Holographic HUD Overlays -->
  <!-- Crosshair center radar -->
  <circle cx="400" cy="210" r="70" fill="none" stroke="url(#neon-hud)" stroke-width="1" stroke-dasharray="4,6" />
  <circle cx="400" cy="210" r="35" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-dasharray="20,10" />
  <circle cx="400" cy="210" r="5" fill="#22c55e" />
  <line x1="320" y1="210" x2="380" y2="210" stroke="#22c55e" stroke-width="1" />
  <line x1="420" y1="210" x2="480" y2="210" stroke="#22c55e" stroke-width="1" />
  <line x1="400" y1="130" x2="400" y2="190" stroke="#22c55e" stroke-width="1" />
  <line x1="400" y1="230" x2="400" y2="290" stroke="#22c55e" stroke-width="1" />

  <!-- Digital Readouts -->
  <g fill="#22c55e" font-family="monospace" font-size="9" opacity="0.8">
    <text x="140" y="365">VELOCITY: 42,910 KM/S</text>
    <text x="140" y="380">THRUST: 94.2% [WARP MAX]</text>
    <text x="140" y="395">T-ETA: 02H 43M 37S</text>
    
    <text x="660" y="365" text-anchor="end">SYS_ID: 1000059658</text>
    <text x="660" y="380" text-anchor="end">RADAR: AUTO_ACTIVE</text>
    <text x="660" y="395" text-anchor="end">COORDS: 42.92 // -81.04</text>
  </g>

  <!-- Level ladder scale HUD left -->
  <g stroke="#06b6d4" stroke-width="1" opacity="0.5">
    <path d="M 280 150 L 290 150 L 290 270 L 280 270" fill="none" />
    <line x1="285" y1="170" x2="290" y2="170" />
    <line x1="280" y1="190" x2="290" y2="190" />
    <line x1="285" y1="210" x2="290" y2="210" stroke-width="2" />
    <line x1="280" y1="230" x2="290" y2="230" />
    <line x1="285" y1="250" x2="290" y2="250" />
  </g>

  <!-- Level ladder scale HUD right -->
  <g stroke="#06b6d4" stroke-width="1" opacity="0.5">
    <path d="M 520 150 L 510 150 L 510 270 L 520 270" fill="none" />
    <line x1="515" y1="170" x2="510" y2="170" />
    <line x1="520" y1="190" x2="510" y2="190" />
    <line x1="515" y1="210" x2="510" y2="210" stroke-width="2" />
    <line x1="520" y1="230" x2="510" y2="230" />
    <line x1="515" y1="250" x2="510" y2="250" />
  </g>

  <!-- Glowing dash indicators -->
  <circle cx="340" cy="420" r="4" fill="#ef4444" opacity="0.8" />
  <circle cx="355" cy="420" r="4" fill="#eab308" opacity="0.8" />
  <circle cx="370" cy="420" r="4" fill="#22c55e" opacity="0.8" />
  
  <rect x="425" y="415" width="25" height="8" rx="2" fill="#0ea5e9" opacity="0.6" />
  <rect x="455" y="415" width="25" height="8" rx="2" fill="#0ea5e9" opacity="0.3" />

  <!-- Anamorphic Lens Flare Line -->
  <line x1="0" y1="210" x2="800" y2="210" stroke="#38bdf8" stroke-width="0.75" opacity="0.4" />
  <ellipse cx="400" cy="210" rx="150" ry="25" fill="url(#planet-glow)" opacity="0.1" />

  <!-- Top Cinema Black Bar -->
  <rect width="800" height="50" fill="#000000" />
  <!-- Bottom Cinema Black Bar -->
  <rect y="400" width="800" height="50" fill="#000000" />

  <!-- Video Time stamp overlay -->
  <text x="40" y="32" font-family="monospace" font-size="11" fill="#475569" letter-spacing="1">CLIP: 1000059658_RAW</text>
  <text x="760" y="32" font-family="monospace" font-size="11" fill="#475569" letter-spacing="1" text-anchor="end">01:42:09:23</text>
</svg>
