<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 600" width="100%" height="100%">
  <!-- Background -->
  <defs>
    <radialGradient id="bg-grad" cx="50%" cy="50%" r="75%">
      <stop offset="0%" stop-color="#141a29" />
      <stop offset="50%" stop-color="#0c0f17" />
      <stop offset="100%" stop-color="#05060a" />
    </radialGradient>
    <linearGradient id="orbit-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.8" />
      <stop offset="50%" stop-color="#f59e0b" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#d97706" stop-opacity="0" />
    </linearGradient>
    <radialGradient id="glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3" />
      <stop offset="100%" stop-color="#3b82f6" stop-opacity="0" />
    </radialGradient>
  </defs>

  <rect width="400" height="600" fill="url(#bg-grad)" />

  <!-- Stars / Particles -->
  <g fill="#ffffff" opacity="0.4">
    <circle cx="45" cy="80" r="1.5" />
    <circle cx="320" cy="110" r="1" />
    <circle cx="120" cy="240" r="1" />
    <circle cx="280" cy="280" r="1.5" />
    <circle cx="80" cy="350" r="1" />
    <circle cx="340" cy="400" r="2" />
    <circle cx="160" cy="480" r="1" />
    <circle cx="290" cy="60" r="1" />
  </g>

  <!-- Glowing core -->
  <circle cx="200" cy="280" r="150" fill="url(#glow)" />

  <!-- Spheres & Orbit Lines -->
  <ellipse cx="200" cy="280" rx="130" ry="60" fill="none" stroke="url(#orbit-grad)" stroke-width="1.5" transform="rotate(-15 200 280)" />
  <ellipse cx="200" cy="280" rx="160" ry="35" fill="none" stroke="#ef4444" stroke-opacity="0.4" stroke-width="1" stroke-dasharray="4,4" transform="rotate(25 200 280)" />

  <!-- Main planet -->
  <circle cx="200" cy="280" r="45" fill="#1e293b" stroke="#4b5563" stroke-width="2" />
  <!-- Shadow overlay on planet -->
  <path d="M 160 260 A 45 45 0 0 0 240 300 A 45 45 0 0 1 160 260" fill="#05060a" opacity="0.8" />
  <!-- Crescent rim light -->
  <path d="M 155 280 A 45 45 0 0 1 200 235 A 44 44 0 0 0 162 262 A 44 44 0 0 0 155 280" fill="#fef08a" opacity="0.6" />

  <!-- Retro Lines Overlay -->
  <g stroke="#ffffff" stroke-opacity="0.05" stroke-width="1">
    <line x1="200" y1="0" x2="200" y2="600" />
    <line x1="0" y1="300" x2="400" y2="300" />
  </g>

  <!-- Typography / Poster Layout -->
  <text x="200" y="70" text-anchor="middle" font-family="'Georgia', serif" font-size="12" fill="#d97706" letter-spacing="4" font-weight="bold">A CINEMOOD ORIGINAL</text>
  
  <text x="200" y="140" text-anchor="middle" font-family="'Helvetica Neue', 'Arial', sans-serif" font-size="36" fill="#f8fafc" letter-spacing="8" font-weight="900">SYSTEM</text>
  <text x="200" y="180" text-anchor="middle" font-family="'Helvetica Neue', 'Arial', sans-serif" font-size="36" fill="#f8fafc" letter-spacing="8" font-weight="900">FAILURE</text>
  
  <text x="200" y="210" text-anchor="middle" font-family="'Georgia', serif" font-size="10" fill="#94a3b8" letter-spacing="2" font-style="italic">In space, there is no root access.</text>

  <!-- Technical Specs Block at Bottom -->
  <g fill="#475569" font-family="monospace" font-size="9" letter-spacing="1">
    <text x="50" y="490">FRAME: 1000059655</text>
    <text x="50" y="505">CAM: PANAVISION C-SERIES</text>
    <text x="350" y="490" text-anchor="end">RATIO: 2.39:1</text>
    <text x="350" y="505" text-anchor="end">LOC: CLUSTER-7</text>
  </g>

  <!-- Billing Block / Movie Credits -->
  <rect x="40" y="520" width="320" height="1" fill="#1e293b" />
  <text x="200" y="540" text-anchor="middle" font-family="sans-serif" font-size="7" fill="#64748b" letter-spacing="1.5">
    DIRECTED BY <tspan fill="#94a3b8">ALEXANDER VANCE</tspan> PRODUCED BY <tspan fill="#94a3b8">CINEMOOD LABS</tspan>
  </text>
  <text x="200" y="555" text-anchor="middle" font-family="sans-serif" font-size="7" fill="#64748b" letter-spacing="1.5">
    MUSIC BY <tspan fill="#94a3b8">HANS ZIMMER II</tspan> DIRECTOR OF PHOTOGRAPHY <tspan fill="#94a3b8">LUCAS BELLO</tspan>
  </text>
  <text x="200" y="575" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#d97706" letter-spacing="5" font-weight="bold">COMING WINTER 2026</text>
</svg>
